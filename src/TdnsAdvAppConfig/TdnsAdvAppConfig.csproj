<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.1.4</Version>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RootNamespace>TdnsAdvAppConfig</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- config.json is a local runtime file (gitignored, holds real secrets) that the SDK's
         default content glob would otherwise publish - which previously let a `dotnet publish`
         + `scp -r publish/*` overwrite a real deployment's config.json with dev-machine values.
         pause-timers.json is excluded for the same reason (runtime state, not source). -->
    <Content Remove="config.json" />
    <Content Remove="pause-timers.json" />
    <None Include="config.json" Condition="Exists('config.json')" CopyToOutputDirectory="Never" CopyToPublishDirectory="Never" />
  </ItemGroup>

</Project>
